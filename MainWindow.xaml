<Window x:Class="Kursovaia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kursovaia"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Background="#4f535b">

    <Window.Resources>
        <Style x:Key="TypeOfButtons" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5 25"/>
            <Setter Property="Background" Value="#f4a61f"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border
        Grid.Row="0" Grid.ColumnSpan="3"
        Height="100"
            Background="#f4a61f">
            <TextBlock Text="Доставка Еды"
                       FontSize="30"
                       FontWeight="DemiBold"
                       HorizontalAlignment="Center"/>
        </Border>

        <Border
         Grid.Row="1" Grid.ColumnSpan="3"
         Background="#303236"
         Height="100">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" 
                    HorizontalAlignment="Center">
                <Button Content="Пользователи" 
        Style="{StaticResource ResourceKey=TypeOfButtons}"
                 Click="OpenUsersPage"/>
                <Button Content="Рестораны"
        Style="{StaticResource ResourceKey=TypeOfButtons}"
                Click="OpenRestaurantPage"/>
                <Button Content="Заказы"
        Style="{StaticResource ResourceKey=TypeOfButtons}"
                Click="OpenOrderPage"/>
            </StackPanel>
        </Border>

        <Frame x:Name="Main"
              Grid.ColumnSpan="3"
               Grid.RowSpan="3">
            
        </Frame>

    </Grid>
</Window>